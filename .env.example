# Local/dev defaults
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional staging-specific values (used by --mode staging)
# Copy to .env.staging.local for local testing:
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Server-only bootstrap admin variables (do not expose to browser)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# BOOTSTRAP_ADMIN_EMAIL=
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_UPDATE_PASSWORD=false

# Server-only user role update script variables
# TARGET_USER_EMAIL=
# SET_IS_ADMIN=false
# SET_IS_GM=false
