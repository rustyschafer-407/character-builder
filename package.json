{
  "name": "character-builder",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "sync:roll20-sheet": "node scripts/sync-roll20-sheet.mjs",
    "dev": "vite",
    "dev:staging": "vite --mode staging",
    "build": "npm run sync:roll20-sheet && tsc -b && vite build",
    "build:staging": "npm run sync:roll20-sheet && tsc -b && vite build --mode staging",
    "bootstrap:admin": "node scripts/bootstrap-admin.mjs",
    "user:delete": "node scripts/delete-user.mjs",
    "roles:set": "node scripts/set-user-global-roles.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
